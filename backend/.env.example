# SecureHealth Backend Environment Variables

# Firebase Configuration
FIREBASE_PROJECT_ID=health-vault-3fa27
FIREBASE_PRIVATE_KEY_ID=your-private-key-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=your-client-id
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token
FIREBASE_AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
FIREBASE_CLIENT_X509_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/...

# Server
PORT=5000
NODE_ENV=production

# Encryption
ENCRYPTION_KEY=your-32-character-secret-key-here

# Vertex AI (Gemini)
GOOGLE_PROJECT_ID=health-vault-3fa27
GOOGLE_CLOUD_REGION=us-central1

# Razorpay
RAZORPAY_KEY_ID=your-key-id
RAZORPAY_KEY_SECRET=your-key-secret

# Polygon Mumbai (Blockchain)
POLYGON_RPC_URL=https://rpc.ankr.com/polygon_mumbai
POLYGON_PRIVATE_KEY=your-test-wallet-private-key

# ABDM Sandbox
ABDM_API_BASE_URL=https://sandbox.abdm.gov.in
ABDM_CLIENT_ID=your-client-id
ABDM_CLIENT_SECRET=your-client-secret
